root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{cpp,cc,cxx,h,hpp,cu,cuh}]
indent_size = 4
max_line_length = 100

[*.py]
indent_size = 4
max_line_length = 100

[*.{cmake,txt}]
indent_size = 2

[*.{sh,bash}]
indent_size = 2

[*.{md,json,yaml,yml}]
indent_size = 2

[Makefile]
indent_style = tab
