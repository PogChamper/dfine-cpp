# Build outputs (regenerate via trt-files/scripts/)
trt-files/onnx/*.onnx
trt-files/onnx/*.json
trt-files/engines/*.engine
trt-files/engines/*.json
*.timing.cache
# third_party: vendor the small stb header (needed to build the image-decode apps on a
# fresh clone), but ignore third_party/tensorrt (its libs are machine-specific symlinks
# into the sibling D-FINE-seg venv; its public headers are re-fetched — see third_party/README.md).
third_party/*
!third_party/stb/
!third_party/stb/**
!third_party/README.md
# Python
__pycache__/
*.pyc
# Wheel-build transients (build_wheel.sh stages these into the package and trap-cleans)
python/dfine/libdfine.so
python/dfine/_scripts/
python/build/
python/dfine.egg-info/
# Weights
*.pt
*.pth
# C++ build
build/
